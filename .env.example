# ============================================================
# Firebase Configuration (REQUIRED)
# ============================================================
# Get these from: Firebase Console > Project Settings > Your Apps
# Required: Enable Authentication (Email/Password) + Realtime Database
#
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ============================================================
# Onboarding Booking Link (OPTIONAL)
# ============================================================
# Calendar link shown to new users after signup
# Defaults to the Principe Consults booking link if not set
#
VITE_ONBOARDING_BOOKING_LINK=
